# Copy this file to .env and replace the placeholder with your real API key.
# Never commit the .env file to Git.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek's Anthropic-compatible endpoint (used by the anthropic Python SDK).
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-flash

# Agent behavior. THINKING_ENABLED accepts true or false.
THINKING_ENABLED=false
SYSTEM_PROMPT="You are Neil Agent, a helpful local coding assistant. Give accurate, practical, and concise answers."

# Generation and loop limits.
MAX_TOKENS=8192
MAX_ROUNDS=20
# Approximate JSON characters for system prompt, tools, history, and new input.
MAX_CONTEXT_CHARS=120000
MAX_TOOL_ROUNDS=5
REQUEST_TIMEOUT=120
# Transient model failures only. Total attempts are 1 + MAX_RETRIES.
MAX_RETRIES=2
RETRY_BASE_DELAY=1
RETRY_MAX_DELAY=8

# Local tool boundaries. Commands use a fixed allowlist and capped output.
WORKSPACE_ROOT=.
COMMAND_TIMEOUT=120
MAX_COMMAND_OUTPUT_CHARS=20000
