# Copy this file to .env and replace the placeholder with your real API key.
# Never commit the .env file to Git.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek's Anthropic-compatible endpoint (used by the anthropic Python SDK).
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-flash

# Agent behavior. THINKING_ENABLED accepts true or false.
THINKING_ENABLED=false
SYSTEM_PROMPT="You are Neil Agent, a helpful local coding assistant. Give accurate, practical, and concise answers."

# Generation and loop limits.
MAX_TOKENS=8192
MAX_ROUNDS=20
MAX_TOOL_ROUNDS=5
REQUEST_TIMEOUT=120

# Read-only tools cannot access paths outside this directory.
WORKSPACE_ROOT=.
